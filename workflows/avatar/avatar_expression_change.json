{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "_meta": {"title": "Load Checkpoint"},
    "inputs": {
      "ckpt_name": "{{ckpt_name}}"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "_meta": {"title": "Persona Portrait"},
    "inputs": {
      "image": "{{image_path}}"
    }
  },
  "3": {
    "class_type": "VAEEncode",
    "_meta": {"title": "Encode portrait → latent"},
    "inputs": {
      "pixels": ["2", 0],
      "vae": ["1", 2]
    }
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Positive Prompt"},
    "inputs": {
      "clip": ["1", 1],
      "text": "{{positive_prompt}}"
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Negative Prompt"},
    "inputs": {
      "clip": ["1", 1],
      "text": "{{negative_prompt}}"
    }
  },
  "8": {
    "class_type": "KSampler",
    "_meta": {"title": "Img2Img Sampler (low denoise to keep identity)"},
    "inputs": {
      "model": ["1", 0],
      "positive": ["5", 0],
      "negative": ["6", 0],
      "latent_image": ["3", 0],
      "seed": "{{seed}}",
      "steps": "{{steps}}",
      "cfg": "{{cfg}}",
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": "{{denoise}}"
    }
  },
  "9": {
    "class_type": "VAEDecode",
    "_meta": {"title": "Decode → image"},
    "inputs": {
      "samples": ["8", 0],
      "vae": ["1", 2]
    }
  },
  "10": {
    "class_type": "SaveImage",
    "_meta": {"title": "Save"},
    "inputs": {
      "filename_prefix": "avatar/expression",
      "images": ["9", 0]
    }
  }
}
