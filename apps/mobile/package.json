{
  "name": "homepilot-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "typecheck": "tsc --noEmit",
    "icons": "node scripts/generate-icon.mjs",
    "prebuild": "node scripts/generate-icon.mjs && expo prebuild --platform android --no-install",
    "build:android": "cd android && ./gradlew assembleRelease --no-daemon"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "expo": "~51.0.0",
    "expo-av": "~14.0.7",
    "expo-file-system": "~17.0.1",
    "expo-notifications": "~0.28.19",
    "expo-secure-store": "~13.0.2",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "~3.31.1",
    "react-native-sse": "^1.2.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.79",
    "babel-plugin-module-resolver": "^5.0.2",
    "typescript": "~5.3.3"
  }
}
