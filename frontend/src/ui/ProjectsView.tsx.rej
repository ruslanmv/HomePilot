@@ -270,6 +267,80 @@
     void run()
   }, [apiKey, backendUrl, capabilitiesLoaded, projectType])
 
+  // Fetch suite + catalog (best-effort). This powers the "Connections" UX.
+  useEffect(() => {
+    if (projectType !== 'agent') return
+    if (catalogLoaded) return
+
+    const run = async () => {
+      try {
+        const headers: Record<string, string> = {}
+        if (apiKey) headers['x-api-key'] = apiKey
+
+        const [suiteRes, catRes] = await Promise.all([
+          fetch(`${backendUrl}/v1/agentic/suite/default_pro`, { headers }),
+          fetch(`${backendUrl}/v1/agentic/catalog`, { headers }),
+        ])
+
+        if (suiteRes.ok) setAgenticSuite(await suiteRes.json())
+        if (catRes.ok) setAgenticCatalog(await catRes.json())
+      } catch {
+        // best-effort: allow wizard to continue without Forge
+      } finally {
+        setCatalogLoaded(true)
+      }
+    }
+
+    void run()
+  }, [apiKey, backendUrl, catalogLoaded, projectType])
+
+  const refreshCatalog = async () => {
+    try {
+      const headers: Record<string, string> = {}
+      if (apiKey) headers['x-api-key'] = apiKey
+      const catRes = await fetch(`${backendUrl}/v1/agentic/catalog`, { headers })
+      if (catRes.ok) setAgenticCatalog(await catRes.json())
+    } catch {
+      // ignore
+    }
+  }
+
+  const toggleA2A = (id: string) => {
+    setSelectedA2AAgents((prev) => (prev.includes(id) ? prev.filter((x) => x !== id) : [...prev, id]))
+  }
+
+  const resolveToolPreview = () => {
+    const tools: any[] = Array.isArray(agenticCatalog?.tools) ? agenticCatalog.tools : []
+    const servers: any[] = Array.isArray(agenticCatalog?.virtual_servers) ? agenticCatalog.virtual_servers : []
+    const gateways: any[] = Array.isArray(agenticCatalog?.gateways) ? agenticCatalog.gateways : []
+
+    const byId = new Map<string, any>(tools.map((t) => [String(t.id), t]))
+
+    if (toolSourceId === 'all_enabled') {
+      return tools.filter((t) => t.enabled !== false)
+    }
+
+    const suiteSources: any[] = Array.isArray(agenticSuite?.tool_sources) ? agenticSuite.tool_sources : []
+    const source = suiteSources.find((s) => String(s.id) === toolSourceId)
+    if (!source) return []
+
+    if (source.kind === 'virtual_server') {
+      const match = servers.find((s) => String(s.name) === String(source.match))
+      const ids: string[] = Array.isArray(match?.tool_ids) ? match.tool_ids.map(String) : []
+      return ids.map((id) => byId.get(id)).filter(Boolean)
+    }
+
+    if (source.kind === 'gateway') {
+      // If Forge exposes tool origin metadata, prefer it. Otherwise, show all enabled tools.
+      const gw = gateways.find((g) => String(g.name) === String(source.match))
+      const gwId = gw?.id
+      const filtered = tools.filter((t) => (gwId ? String(t.gateway_id || t.origin_gateway_id || '') === String(gwId) : false))
+      return filtered.length ? filtered : tools.filter((t) => t.enabled !== false)
+    }
+
+    return tools.filter((t) => t.enabled !== false)
+  }
+
   // Smart defaults: preselect capabilities that match the user's goal text
   useEffect(() => {
     if (projectType !== 'agent') return
