{
  "schema_version": 1,
  "personality_tools": {
    "description": "Simple tool IDs from PersonalityAgent.allowed_tools",
    "tools": [
      "community_greet",
      "community_farewell",
      "community_compliment"
    ]
  },
  "forge_tools": {
    "description": "Tool references from Context Forge / MCP",
    "tools": [
      "hp.community.greeter.greet",
      "hp.community.greeter.farewell",
      "hp.community.greeter.compliment"
    ]
  },
  "tool_schemas": [
    {
      "name": "hp.community.greeter.greet",
      "description": "Generate a personalized greeting for someone",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Person's name" },
          "language": { "type": "string", "default": "en", "description": "Language code" },
          "style": { "type": "string", "enum": ["formal", "casual", "enthusiastic"], "default": "casual" }
        },
        "required": ["name"]
      }
    },
    {
      "name": "hp.community.greeter.farewell",
      "description": "Generate a thoughtful farewell message",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Person's name" },
          "context": { "type": "string", "description": "Why they are leaving (end of day, trip, etc.)" }
        },
        "required": ["name"]
      }
    },
    {
      "name": "hp.community.greeter.compliment",
      "description": "Generate a genuine, specific compliment",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Person's name" },
          "topic": { "type": "string", "description": "What to compliment (work, creativity, kindness, etc.)" }
        },
        "required": ["name"]
      }
    }
  ],
  "capability_summary": {
    "required": [],
    "optional": []
  }
}
