+# ── GET /v1/agentic/catalog ────────────────────────────────────────────────
+
+@router.get("/catalog")
+async def agentic_catalog(_key: str = Depends(require_api_key)):
+    """Return a UI-friendly catalog from Context Forge.
+
+    Includes:
+      - tools
+      - a2a_agents
+      - gateways
+      - virtual_servers
+
+    This is additive (doesn't change invocation routing). It exists so the
+    wizard can show real objects (bundles, tools, agents) instead of placeholder
+    "capabilities".
+    """
+
+    if not _ENABLED:
+        return {"last_updated": None, "tools": [], "a2a_agents": [], "gateways": [], "virtual_servers": []}
+    try:
+        return await fetch_catalog(_client())
+    except Exception as exc:
+        logger.warning("catalog fetch failed: %s", exc)
+        return {"error": str(exc), "last_updated": None, "tools": [], "a2a_agents": [], "gateways": [], "virtual_servers": []}
+
+
+# ── GET /v1/agentic/suite/* ────────────────────────────────────────────────
+
+@router.get("/suite")
+async def agentic_suite_index(_key: str = Depends(require_api_key)):
+    """Return all known suite manifests."""
+    return list_suites()
+
+
+@router.get("/suite/{name}")
+async def agentic_suite(name: str, _key: str = Depends(require_api_key)):
+    """Return a single suite manifest by name (without extension)."""
+    return read_suite(name)
+
+
 # ── POST /v1/agentic/invoke ──────────────────────────────────────────────────
