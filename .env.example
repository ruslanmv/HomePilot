# HomePilot Environment Configuration
# Copy this file to .env and edit for your setup

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# Frontend API URL (where the React app sends requests)
# - For local development: http://localhost:8000
# - For docker: http://backend:8000
VITE_API_URL=http://localhost:8000

# =============================================================================
# SECURITY
# =============================================================================

# Optional API key (if set, backend requires it on all requests)
# Leave empty for no authentication (local development)
API_KEY=

# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================

# Default provider: "openai_compat" (vLLM) or "ollama"
DEFAULT_PROVIDER=ollama

# --- vLLM / OpenAI-compatible endpoint ---
# Use this for high-performance LLM serving
LLM_BASE_URL=http://llm:8001/v1
LLM_MODEL=local-model

# --- Ollama (recommended for local development) ---
# Install Ollama: https://ollama.ai
# Run: ollama serve
# Pull a model: ollama pull llama3:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# =============================================================================
# IMAGE & VIDEO GENERATION (ComfyUI)
# =============================================================================

# ComfyUI server URL
# - For local development: http://localhost:8188
# - For docker: http://comfyui:8188
COMFY_BASE_URL=http://localhost:8188

# ComfyUI workflows directory (auto-detected in local dev, set explicitly if needed)
# COMFY_WORKFLOWS_DIR=/path/to/comfyui/workflows

# ComfyUI polling settings
COMFY_POLL_INTERVAL_S=1.0   # Check for completion every 1 second
COMFY_POLL_MAX_S=240        # Timeout after 4 minutes

# =============================================================================
# MEDIA PROCESSING
# =============================================================================

# Media service (FFMPEG-based) URL
MEDIA_BASE_URL=http://media:8002

# =============================================================================
# STORAGE
# =============================================================================

# SQLite database path (conversation history)
# - For local development: ./backend/data/homepilot.db
# - For docker: /app/data/homepilot.db
SQLITE_PATH=/app/data/homepilot.db

# File upload directory
UPLOAD_DIR=/app/data/uploads

# Output directory (generated images/videos)
OUTPUT_DIR=/outputs

# Max upload size (MB)
MAX_UPLOAD_MB=25

# =============================================================================
# TIMEOUTS
# =============================================================================

# General tool timeout (seconds)
TOOL_TIMEOUT_S=300

# =============================================================================
# CORS (Cross-Origin Resource Sharing)
# =============================================================================

# Allowed origins (comma-separated)
# - For local development: add your frontend URLs
# - For production: set to your domain
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# =============================================================================
# MCP CONTEXT FORGE (Agentic Features)
# =============================================================================

# Enable MCP Gateway integration (set to false to disable)
MCP_ENABLED=true

# MCP Gateway URL (where the gateway listens)
MCP_GATEWAY_URL=http://localhost:4444

# MCP Gateway authentication (generate with: make start-mcp, then create token via Admin UI)
# MCPGATEWAY_BEARER_TOKEN=

# MCP Gateway Admin UI (required for "Open Tool & Agent Manager" link)
MCPGATEWAY_UI_ENABLED=true
MCPGATEWAY_ADMIN_API_ENABLED=true
# Disable login prompt so Admin UI opens without password (local dev)
AUTH_REQUIRED=false

# LLM provider for the LangChain agent (openai, azure, bedrock, ollama, anthropic)
# MCP_LLM_PROVIDER=ollama
# MCP_LLM_MODEL=llama3:8b

# --- Agentic AI Layer (backend → Context Forge bridge) ---
# Feature flag (true/false) — when false, /v1/agentic/* returns disabled status
AGENTIC_ENABLED=true
# Context Forge gateway URL (same as MCP_GATEWAY_URL by default)
CONTEXT_FORGE_URL=http://localhost:4444
# Admin UI URL (for "Open Tool & Agent Manager" button in Settings)
CONTEXT_FORGE_ADMIN_URL=http://localhost:4444/admin
# Pre-configured JWT Bearer token (leave empty for auto-login via /auth/login)
# CONTEXT_FORGE_TOKEN=
# Auth credentials for JWT auto-login (email derived as {user}@example.com)
# Forge requires JWT tokens — these credentials are used to acquire one automatically
CONTEXT_FORGE_AUTH_USER=admin
CONTEXT_FORGE_AUTH_PASS=changeme

# =============================================================================
# COMMUNITY GALLERY
# =============================================================================

# Primary: Cloudflare Worker proxy (edge-cached, no rate limits, clean URLs)
# Deployed with: make community-deploy-worker
COMMUNITY_GALLERY_URL=https://homepilot-persona-gallery.cloud-data.workers.dev

# Fallback: R2 direct public access (rate-limited by Cloudflare, dev use only)
# Enable public access on R2 bucket: Dashboard → R2 → bucket → Settings → Public Access
R2_PUBLIC_URL=https://pub-0274961e62694c09bdb4c8f2822ca3f1.r2.dev
#
# Priority: COMMUNITY_GALLERY_URL (Worker) takes precedence over R2_PUBLIC_URL (R2 direct).
# To fall back to R2 direct, comment out or remove COMMUNITY_GALLERY_URL.

# =============================================================================
# MCP SERVER CONFIGURATION (Ports 9101–9202)
# =============================================================================
# These variables configure the individual MCP servers started via
# docker-compose.mcp.yml or scripts/persona-launch.sh.
# All write operations are DISABLED by default (safe for local dev).

# --- Global Write-Gating (applies to all servers unless overridden) ---
WRITE_ENABLED=false
DRY_RUN=true

# --- Web Search (port 9105) ---
# Provider: "searxng" (self-hosted, free) or "tavily" (enterprise API)
WEB_SEARCH_PROVIDER=searxng
SEARXNG_BASE_URL=http://localhost:8080
# TAVILY_API_KEY=

# --- Local Notes (port 9110) ---
NOTES_WRITE_ENABLED=false
NOTES_DRY_RUN=true

# --- Local Projects (port 9111) ---
PROJECTS_WRITE_ENABLED=false
PROJECTS_DRY_RUN=true
PROJECTS_MOUNT_PATH=./data/projects
# ALLOWED_ROOTS=   # Comma-separated list of allowed project directory roots

# --- Shell Safe (port 9113) ---
SHELL_WRITE_ENABLED=false
# SHELL_EXEC_TIMEOUT=30          # Command execution timeout (seconds)
# SHELL_ALLOW_NETWORK=false      # Allow curl, wget, ssh, etc.

# --- Gmail (port 9114) ---
GMAIL_WRITE_ENABLED=false
GMAIL_CONFIRM_SEND=true

# --- Google Calendar (port 9115) ---
GCAL_WRITE_ENABLED=false

# --- Microsoft Graph (port 9116) ---
MSGRAPH_WRITE_ENABLED=false
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=
# MS_GRAPH_TENANT_ID=

# --- Slack (port 9117) ---
SLACK_WRITE_ENABLED=false
# SLACK_BOT_TOKEN=

# --- GitHub (port 9118) ---
GITHUB_WRITE_ENABLED=false
# GITHUB_TOKEN=
# GITHUB_ORG=

# --- Notion (port 9119) ---
NOTION_WRITE_ENABLED=false
# NOTION_TOKEN=

# --- Persona Launcher (scripts/persona-launch.sh) ---
# HEALTH_TIMEOUT=5               # Health check timeout per server (seconds)
# STARTUP_TIMEOUT=30             # Post-startup stabilization wait (seconds)
# AUTO_REGISTER=true             # Auto-register tools in Forge after startup

# =============================================================================
# ADVANCED
# =============================================================================

# Public base URL (for generating links)
# PUBLIC_BASE_URL=https://your-domain.com

# =============================================================================
# LOCAL DEVELOPMENT QUICK START
# =============================================================================
#
# 1. Install Ollama: https://ollama.ai
# 2. Run: ollama pull llama3:8b
# 3. Start Ollama: ollama serve
# 4. Install ComfyUI: https://github.com/comfyanonymous/ComfyUI
# 5. Start ComfyUI: python main.py
# 6. Copy this file to .env
# 7. Update the following settings:
#    - DEFAULT_PROVIDER=ollama
#    - OLLAMA_BASE_URL=http://localhost:11434
#    - OLLAMA_MODEL=llama3:8b
#    - COMFY_BASE_URL=http://localhost:8188
# 8. Start backend: cd backend && uvicorn app.main:app --reload
# 9. Start frontend: cd frontend && npm run dev
# 10. Open http://localhost:3000
#
# For Grok-like "Imagine" feature:
# - Create ComfyUI workflows (see comfyui/workflows/README.md)
# - The backend will auto-detect workflows in local development
#
# =============================================================================
# PHONE / VOICE-CALL FEATURE (ADDITIVE, FEATURE-FLAGGED, DEFAULT OFF)
# =============================================================================
# The emerald 📞 in the chat header opens the Call overlay. Without these
# flags the frontend falls back to the regular chat REST path (same model,
# no persona-aware opening, no backchannels, no filler). With the flags on
# the call routes through /v1/voice-call/ws/{id} and persona_call composes
# a per-turn system suffix on top of each persona.
#
# Required for the Call overlay to actually open a session:
#
# VOICE_CALL_ENABLED=true          # mounts POST /v1/voice-call/sessions + WS
# VOICE_CALL_WEBSOCKET_ENABLED=true # accepts WS handshakes (default true when VC is on)
#
# Required for the persona to answer first ("theory of answering"):
#
# PERSONA_CALL_ENABLED=true        # loads the persona_call module
# PERSONA_CALL_APPLY=true          # attach the suffix to the LLM call
#                                  # (leave false for shadow-compose mode)
#
# Optional tuning knobs — safe defaults in persona_call/config.py:
#
# PERSONA_CALL_FILLER_AFTER_MS=600         # trouble threshold (Stivers 2009)
# PERSONA_CALL_BC_MIN_GAP_MS=1800          # cooldown between backchannels
# PERSONA_CALL_HAY_LATE_HOUR=21            # skip "how are you" at or after
# PERSONA_CALL_LATE_HOUR=22                 # enter late-night brevity
# PERSONA_CALL_LATE_HOUR_END=6              # exit late-night brevity
# PERSONA_CALL_REASON_FALLBACK_TURN=3       # promote opening→topic by turn N
# VOICE_CALL_MAX_DURATION_SEC=2700          # 45 min cap
# VOICE_CALL_RESUME_WINDOW_SEC=20           # resume window after a drop
#
# Symptom you'll see if these aren't set:
#   POST /v1/voice-call/sessions → 404
# The call overlay still opens (visual-only shell), but the persona
# never speaks first and the chat-REST path carries every turn. See
# docs/PHONE.md § 6 "Running it yourself" for the full rollout plan.
# =============================================================================

# =============================================================================
# MOBILE VOICE BACKEND + PREMIUM (MB2–MB6, ADDITIVE, DEFAULT OFF)
# =============================================================================
# The backend voice session (WS /v1/voice/session) orchestrates STT → LLM → TTS
# server-side so the mobile (and, later, web) client stays thin. Everything here
# is default-off / default-free: leaving it unset preserves today's behaviour
# exactly. See PRODUCTION.md "Voice & premium" for the full rollout.
#
# --- Turn the voice session route on (otherwise the WS rejects connections) ---
# VOICE_BACKEND_ENABLED=true
#
# --- Free voice (local Piper TTS — the engine HomePilot already uses) ---
# Active only when a Piper voice model is present; otherwise voice is text-only.
# PIPER_BINARY=piper                       # binary on PATH (default: "piper")
# PIPER_VOICE_MODEL=/path/to/voice.onnx    # required to produce audio
#
# --- Free speech-to-text (local faster-whisper) ---
# Active only when WHISPER_MODEL is set AND the faster-whisper package is
# installed. Leave unset to run voice text-in/voice-out only.
# WHISPER_MODEL=base                       # e.g. base, small, medium
#
# --- Premium neural voice (entitlement seam — no client change) ---
# When PREMIUM_VOICE_ENABLED=true AND a neural TTS endpoint is configured,
# entitled sessions use low-latency neural TTS; everyone else stays on Piper.
# Both STT/TTS speak the OpenAI-compatible /audio/* shape (OpenAI, Groq,
# ElevenLabs-compatible gateways, a local whisper.cpp server, …).
# PREMIUM_VOICE_ENABLED=true
# TTS_BASE_URL=https://api.openai.com/v1   # required to enable neural TTS
# TTS_API_KEY=sk-...                       # optional (some gateways need none)
# TTS_MODEL=tts-1                          # default: tts-1
# TTS_VOICE=alloy                          # default: alloy
# STT_BASE_URL=https://api.openai.com/v1   # required to enable cloud STT
# STT_API_KEY=sk-...                       # optional
# STT_MODEL=whisper-1                      # default: whisper-1
#
# =============================================================================
# CLOUD-GPU BURST ("works when your PC is off" — MB6, ADDITIVE)
# =============================================================================
# In HOMEPILOT_COMPUTE_MODE=auto, when the local GPU is offline HomePilot can
# burst generation to a paired GPU via OllaBridge Cloud. The local GPU is never
# gated. By default the burst works for everyone (current behaviour preserved);
# flip it to a premium feature with the two flags below.
#
# HOMEPILOT_COMPUTE_MODE=local             # local | ollabridge_cloud | auto
# OLLABRIDGE_CLOUD_URL=https://ruslanmv-ollabridge.hf.space   # the live Space
# OLLABRIDGE_CLOUD_TOKEN=                   # cloud access token (Bearer/ob_ key)
# OLLABRIDGE_CLOUD_IMAGE_MODEL=flux-schnell
# OLLABRIDGE_CLOUD_VIDEO_MODEL=ltx-video
# OLLABRIDGE_CLOUD_TIMEOUT=300
#
# Make the burst a premium-only feature (off by default → everyone can burst):
# COMPUTE_BURST_REQUIRES_PREMIUM=true      # require entitlement for the burst
# PREMIUM_COMPUTE_ENABLED=true             # the global entitlement (a per-user
#                                          # check replaces this once billing exists)
# =============================================================================

# =============================================================================
# ESSAY-TO-VIDEO PIPELINE (Creator Studio — ADDITIVE, Batches 0-4)
# =============================================================================
# Turns a ruslanmv.com essay (or any markdown script) into a full-length
# video, a Short, and a 1:1 teaser. Design: docs/design/essay-to-video/.
# Every setting below is optional — the pipeline degrades gracefully:
# no WhisperX -> proportional scene timing; no Kokoro -> no short-form TTS;
# no ComfyUI -> motion-graphic scenes still render deterministically.
#
# Essay ingestion — "url" scrapes the rendered page; "repo" prefers raw
# Jekyll markdown when the URL points at one (github blob / *.md).
# ESSAY_IMPORT_SOURCE=url                  # url | repo
#
# Forced alignment (optional: pip install whisperx). Without it, scene
# durations distribute proportionally by word count — still sentence-cut.
# WHISPERX_MODEL=large-v3
# WHISPERX_DEVICE=cuda                     # falls back to cpu automatically
#
# Local audio paths in existing_audio_url are refused unless enabled —
# only turn this on for trusted single-user installs.
# STUDIO_ALLOW_LOCAL_AUDIO=false
#
# Short-form TTS in the same voice as the essay narration
# (optional: pip install kokoro). Pin the voice used by the essays.
# KOKORO_VOICE_ID=af_heart
# KOKORO_LANG_CODE=a                       # a = American English
# CHATTERBOX_ENABLED=false                 # punchier alt voice (pip install chatterbox-tts)
# CHATTERBOX_DEVICE=cpu
#
# Studio Model Manager — Hugging Face first for base checkpoints,
# civitai.com (never .red) for LoRAs/style layers. License allowlist
# enforced; unlicensed models cannot register.
# CIVITAI_API_KEY=                         # from developer.civitai.com
# HF_TOKEN=                                # only for gated HF repos (e.g. FLUX dev)
# MODEL_SOURCE_PREFERENCE=huggingface_first
# MODEL_REGISTRY_PATH=                     # default: backend/data/installed_models.json
#
# Render output directories (defaults under backend/data/)
# MOTION_GRAPHICS_DIR=                     # deterministic PNG stills
# STUDIO_FILES_DIR=                        # condensed audio, promoted snapshots
#
# Remotion (animated motion graphics + final assembly — JS toolchain,
# see frontend/src/ui/studio/remotion/README.md). Free for individuals
# and small teams; re-check the tier if HomePilot ships this broadly.
# REMOTION_LICENSE_TIER=individual
# =============================================================================

# =============================================================================
# OLLABRIDGE CLOUD MIRROR — Phase 1: Node Manifest (ADDITIVE, OFF BY DEFAULT)
# =============================================================================
# Localhost-only description of this HomePilot install that OllaBridge Local
# reads and republishes (owner-scoped) to the cloud, so the cloud UI can
# mirror local resources without copying model weights or databases.
# Design: docs/design/ollabridge-cloud-mirror/README.md
#
# Disabling this changes nothing else - the legacy /v1 provider plane
# (OLLABRIDGE_LEGACY_PROVIDER_ENABLED) is independent and must stay on.
# OLLABRIDGE_NODE_MANIFEST_ENABLED=false     # serve GET /v1/node/manifest
# HOMEPILOT_NODE_NAME=                        # friendly name (default: hostname)
# HOMEPILOT_NODE_ID=                          # stable id (default: hashed hostname)
# NODE_MANIFEST_ALLOW_HOSTS=                  # extra hosts (e.g. sidecar on a
#                                             # private Docker network), comma-sep
#
# Phase 2 — read-only mirror RPC (/v1/node/rpc). Localhost-only whitelist of
# named getters (services/models/personas/projects/workflows/safe-settings);
# never an arbitrary localhost proxy. Independent of the manifest flag.
# HOMEPILOT_MIRROR_RPC_ENABLED=false
#
# Phase 3 — durable jobs + artifacts (/v1/node/jobs, /v1/node/artifacts).
# Long-running chat/image/video ops with progress; outputs stored as
# short-lived, owner-scoped artifacts (no public URLs). Independent flag.
# HOMEPILOT_MIRROR_JOBS_ENABLED=false
# NODE_ARTIFACT_TTL_SEC=3600                  # artifact lifetime (min 60s)
# NODE_ARTIFACT_MAX_MB=64                     # per-artifact size cap
# NODE_ARTIFACTS_DIR=                         # default: backend/data/node_artifacts
# =============================================================================
